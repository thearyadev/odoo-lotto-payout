<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="console_log_button.ConsoleLogButton">
        <button class="btn btn-secondary control-button btn-lg" style="font-size: 1.8em; padding: 25px 40px;" t-on-click="onClick">
            <i class="fa fa-ticket me-1"/>
            Lotto Payout
        </button>
    </t>

    <t t-name="point_of_sale.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <ConsoleLogButton/>
        </xpath>
    </t>
</templates>
