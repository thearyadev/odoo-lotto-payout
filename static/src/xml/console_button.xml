<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="odoo_lotto_payout.LottoPayoutButton">
        <button class="o_lotto_payout_button btn btn-light btn-lg lh-lg" t-on-click="onClick">
            Payout
        </button>
    </t>

    <t t-name="odoo_lotto_payout.ProductScreen" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//ControlButtons" position="after">
            <LottoPayoutButton t-if="!ui.isSmall"/>
        </xpath>
    </t>
</templates>
